# processkit — recommended .gitignore
#
# Copy this file to `.gitignore` at the root of a new processkit project
# (or append to an existing one). Each section explains why.
#
# Kept in sync with the shipped processkit release; see DEC-20260422_0233-SpryTulip.

# ── processkit runtime ───────────────────────────────────────────────────────
# Regenerable caches and session state. Never commit.

context/.cache/
context/.state/

# ── Privacy convention: user/developer-private files ────────────────────────
# Any directory named `private/` anywhere under context/ is developer-local
# (personal notes, local experiments, non-team-shared content). This pattern
# covers the per-team-member `context/team-members/<slug>/private/` subdirs
# introduced in v0.19.0.

context/**/private/
context/private/

# ── Model catalog cache (optional, v0.19.0+) ────────────────────────────────
# If the model-recommender skill emits a compiled cache from context/models/,
# it goes here. The source of truth is the model artifact files themselves.

context/models/.cache/

# ── Agent-harness-generated files ────────────────────────────────────────────
# Harness-local config that should never be checked in.

.mcp.json
.cursor/mcp.json
.gemini/settings.json
.codex/config.toml
.continue/mcpServers/
.claude/settings.local.json

# ── aibox-generated (only if using aibox; harmless if not) ──────────────────

.aibox-local.toml
.aibox-local.env
.devcontainer/Dockerfile
.devcontainer/docker-compose.yml
.devcontainer/devcontainer.json
.aibox-home/
.root/
.aibox-version
.aibox/
.aibox-backup/
.aibox-env/

# ── OS generated files ──────────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
.Trash-*

# ── Editor / IDE ─────────────────────────────────────────────────────────────

*.swp
*.swo
*~
.idea/
.vscode/

# ── Python ──────────────────────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# ── Docs sites ──────────────────────────────────────────────────────────────

site/
