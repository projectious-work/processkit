{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryFileHeader",
  "type": "object",
  "required": ["tier", "source", "sensitivity", "created"],
  "additionalProperties": true,
  "properties": {
    "tier": {
      "enum": ["working", "episodic", "semantic", "procedural", "relational", "lessons"]
    },
    "source": {
      "enum": ["conversation", "reflection", "imported", "user-edited"]
    },
    "sensitivity": {
      "enum": ["public", "internal", "confidential", "pii"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "importance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "last_reinforced": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {"type": "string"}
  }
}
