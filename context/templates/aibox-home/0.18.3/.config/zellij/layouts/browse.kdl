layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="browse" focus=true {
        pane split_direction="horizontal" {
            pane size="60%" name="files" focus=true {
                command "bash"
                args "-c" "AIBOX_EDITOR_DIR=tab exec yazi"
                cwd "/workspace"
            }
            pane size="40%" {
        pane stacked=true {
        pane name="codex" {
            command "codex"
            cwd "/workspace"
        }
        pane name="claude" {
            command "claude"
            cwd "/workspace"
        }
        }
            }
        }
    }
    tab name="editor" {
        pane name="vim" {
            command "bash"
            args "-c" "AIBOX_EDITOR_DIR=tab exec vim-loop"
            cwd "/workspace"
        }
    }
    tab name="git" {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }
    tab name="shell" {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }
}
